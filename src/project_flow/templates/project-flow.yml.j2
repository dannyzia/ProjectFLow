version: "1.0"

project:
  name: "{{ project_name }}"
  description: "{{ project_description }}"
  tech_stack_file: "docs/Plan/03-TECH-STACK.md"
  output_root: "."
  planning_docs:
    - "docs/Plan/01-PRD.md"
    - "docs/Plan/02-ARCHITECTURE.md"
    - "docs/Plan/03-TECH-STACK.md"

ides:
  vscode: true
  kilo: false
  cursor: false
  windsurf: false
  zed: false
  void: false
  cline: false
  claude: false
  antigravity: false

# Use builtin agents and skills by default
generic_agents: true
generic_skills: true

# User-defined agents (builtin agents will be merged)
agents: []

# User-defined skills (builtin skills will be merged)
skills: []

# User-defined prompts
prompts: []
