{
  "vscode": {
    "agent_file": ".github/agents/{slug}.agent.md",
    "instructions": ".github/copilot-instructions.md",
    "skill_file": ".github/skills/{skill_name}/SKILL.md",
    "prompt_file": ".github/prompts/{filename}",
    "settings": ".vscode/settings.json",
    "agents_md": "AGENTS.md",
    "frontmatter_fields": ["name", "description", "tools", "agents", "handoffs", "model"],
    "settings_keys": {
      "ask_model": "github.copilot.chat.ask.model",
      "edit_model": "github.copilot.chat.edit.model",
      "agent_model": "github.copilot.chat.agent.model"
    },
    "supports_skills": true,
    "supports_prompts": true
  },
  "kilo": {
    "agent_file": ".kilo/files/{slug}.md",
    "config_file": ".kilo.jsonc",
    "skill_file": ".kilo/skills/{skill_name}/SKILL.md",
    "frontmatter_fields": ["name", "description", "tools", "mode", "permission", "color", "model"],
    "config_headers": ["// Kilo Code configuration", "// Auto-generated by project-flow"],
    "supports_skills": true,
    "supports_prompts": false
  },
  "cursor": {
    "rules_file": ".cursorrules",
    "agent_file": ".cursor/rules/{slug}.mdc",
    "skill_file": ".cursor/skills/{skill_name}/SKILL.md",
    "supports_skills": true,
    "supports_prompts": false,
    "frontmatter_fields": ["name", "description"]
  },
  "windsurf": {
    "rules_file": ".windsurfrules",
    "coding_standards": ".windsurf/rules/coding-standards.md",
    "workflow_file": ".windsurf/workflows/{skill_name}.wf.md",
    "supports_skills": false,
    "supports_prompts": false,
    "supports_workflows": true
  },
  "zed": {
    "settings": ".zed/settings.json",
    "context_file": ".zed/prompts/project-context.md",
    "rules_file": ".rules",
    "supports_skills": false,
    "supports_prompts": false
  },
  "void": {
    "rules_file": ".void/rules.md",
    "agent_file": ".void/agents/{slug}.md",
    "supports_skills": false,
    "supports_prompts": false,
    "frontmatter_fields": ["name", "description", "tools"]
  },
  "cline": {
    "skill_file": ".cline/skills/{skill_name}/SKILL.md",
    "supports_skills": true,
    "supports_prompts": false
  },
  "claude": {
    "skill_file": ".claude/skills/{skill_name}/SKILL.md",
    "supports_skills": true,
    "supports_prompts": false
  },
  "antigravity": {
    "rules_dir": ".agents/rules",
    "rule_file": ".agents/rules/{slug}.md",
    "skill_file": ".agents/skills/{skill_name}/SKILL.md",
    "supports_skills": true,
    "supports_prompts": false,
    "frontmatter_fields": ["name", "description"]
  }
}
